# Slides Bot — environment variables
# Copy to .env and fill in real values. .env is gitignored.

# === Cloud.ru Foundation Models ===
# Format: "<key_id>.<secret>" (e.g. "abc123-def456-...d40b51eec567b4df...")
CLOUDRU_API_KEY=
CLOUDRU_BASE_URL=https://foundation-models.api.cloud.ru/v1
# Global RPS limit (Cloud.ru cap is 20 — keep some headroom)
CLOUDRU_RPS_LIMIT=18

# === Telegram ===
TELEGRAM_BOT_TOKEN=
# Comma-separated list of allowed TG user_ids (integer). Bot rejects everyone else.
TELEGRAM_WHITELIST=

# === Redis ===
# Local docker-compose default: redis://redis:6379/0 (worker) | redis://redis:6379/<db> per concern
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# === S3 (Cloud.ru Object Storage) ===
S3_ENDPOINT_URL=https://s3.cloud.ru
S3_REGION=ru-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=slides-bot
S3_TEMPLATE_PREFIX=templates/v5/
S3_SESSION_PREFIX=sessions/

# === Runtime ===
LOG_LEVEL=INFO
SENTRY_DSN=
# Active template version (matches sub-directory in S3 under S3_TEMPLATE_PREFIX)
ACTIVE_TEMPLATE_VERSION=5
# Max concurrent decks across the worker pool (RPS budget = decks * peak_concurrency_per_deck)
MAX_CONCURRENT_DECKS=3
# Halt timeout for stop-the-line user decisions (seconds). 3600 = 1 hour.
HALT_TIMEOUT_SECONDS=3600
# Session bundle TTL in S3 (days)
SESSION_TTL_DAYS=7
