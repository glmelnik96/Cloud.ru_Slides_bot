FROM python:3.10-slim

WORKDIR /app

# LibreOffice + pdftoppm for slide rendering, fontconfig for SB Sans.
RUN apt-get update && apt-get install -y --no-install-recommends \
        libreoffice-impress \
        libreoffice-core \
        poppler-utils \
        fontconfig \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Brand fonts — bind into the system font path so soffice picks them up.
COPY docker/fonts/ /usr/share/fonts/truetype/sbsans/
RUN fc-cache -fv
# Same fonts at the repo-relative path renderers/html/render.py resolves
# (load_brand_css absolutises url() to file://<repo>/docker/fonts/...).
COPY docker/fonts/ /app/docker/fonts/

COPY pyproject.toml ./
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir .

# /html pipeline: headless Chromium for Playwright (renderers/html/render.py).
# --with-deps pulls the system libraries Chromium needs on slim Debian.
RUN playwright install --with-deps chromium \
    && rm -rf /var/lib/apt/lists/*

COPY worker ./worker
COPY graph ./graph
COPY bot ./bot
COPY llm ./llm
COPY schemas ./schemas
COPY storage ./storage
COPY renderers ./renderers
# Top-level scripts/ holds the designer vision-QA render harness
# (scripts.render_png, imported by graph/designer/vision_qa.py). Without it the
# per-slide pixel-judge silently degrades to a no-op in the container.
COPY scripts ./scripts
# Vendored slide-build skill (scripts + brand + dictionaries + .pptx donor
# template). Required by skill_bridge.install() — worker fails fast without it.
COPY skill_assets ./skill_assets

CMD ["celery", "-A", "worker.celery_app", "worker", \
     "--loglevel=INFO", \
     "--concurrency=2", \
     "--prefetch-multiplier=1", \
     "-Q", "default"]
